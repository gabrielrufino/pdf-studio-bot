{
  "name": "@gabrielrufino/pdf-studio-bot",
  "version": "1.4.2",
  "private": true,
  "author": "Gabriel Rufino <contato@gabrielrufino.com>",
  "license": "UNLICENSED",
  "main": "dist/index.js",
  "scripts": {
    "build": "tsc",
    "build:check": "npm run build -- --noEmit",
    "build:watch": "npm run build -- -w",
    "lint": "eslint ./src",
    "lint:fix": "npm run lint -- --fix",
    "start": "node .",
    "start:dev": "tsx watch --env-file=.env src/index.ts",
    "test": "vitest run",
    "test:cov": "npm test -- --coverage",
    "test:watch": "vitest",
    "prepare": "if [[ $NODE_ENV != \"production\" ]]; then husky; fi"
  },
  "dependencies": {
    "@grammyjs/files": "^1.2.0",
    "@grammyjs/runner": "^2.0.3",
    "@grammyjs/storage-mongodb": "^2.5.1",
    "grammy": "^1.41.1",
    "mongodb": "^6.21.0",
    "muhammara": "^5.4.0",
    "pino": "^9.14.0",
    "pino-loki": "^3.0.0",
    "puppeteer": "^24.37.5",
    "zod": "^4.3.6"
  },
  "devDependencies": {
    "@antfu/eslint-config": "^3.16.0",
    "@commitlint/cli": "^19.8.1",
    "@commitlint/config-conventional": "^19.8.1",
    "@faker-js/faker": "^8.4.1",
    "@gabrielrufino/types": "^1.2.1",
    "@vitest/coverage-v8": "^4.0.18",
    "eslint": "^9.39.3",
    "husky": "^9.1.7",
    "mongodb-memory-server": "^10.4.3",
    "pino-pretty": "^13.1.3",
    "tsx": "^4.21.0",
    "typescript": "^5.9.3",
    "vitest": "^4.0.8"
  }
}
